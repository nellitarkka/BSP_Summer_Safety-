# ── Client (public) env — safe to ship in the app bundle ───────────────
# Supabase project URL and ANON key. The anon key is public by design;
# Row Level Security protects all data (see migrations).
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# GraphHopper routing API key (walking routes). Free tier is fine for MVP.
EXPO_PUBLIC_GRAPHHOPPER_KEY=YOUR-GRAPHHOPPER-KEY

# ── Server-only secrets — DO NOT put these in the client / app.config ──
# Set in the Supabase Edge Function secrets, NOT here:
#   supabase secrets set AI_PROVIDER_KEY=sk-ant-...   (Anthropic key)
# See APPLY.md. Required by the generate-safety-tips Edge Function (NFR-04).
